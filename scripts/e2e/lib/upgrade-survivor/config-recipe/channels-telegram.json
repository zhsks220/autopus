{
  "enabled": true,
  "botToken": {
    "source": "env",
    "provider": "default",
    "id": "TELEGRAM_BOT_TOKEN"
  },
  "dmPolicy": "allowlist",
  "allowFrom": ["123456789"],
  "defaultTo": "123456789",
  "groupPolicy": "allowlist",
  "groupAllowFrom": ["123456789"],
  "groups": {
    "-1001234567890": {
      "requireMention": true,
      "tools": {
        "allow": ["message_send"],
        "deny": ["exec"]
      }
    }
  }
}
