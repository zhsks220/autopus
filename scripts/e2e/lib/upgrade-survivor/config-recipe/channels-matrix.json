{
  "enabled": true,
  "homeserver": "https://matrix.example.invalid",
  "userId": "@upgrade-survivor:matrix.example.invalid",
  "accessToken": {
    "source": "env",
    "provider": "default",
    "id": "MATRIX_ACCESS_TOKEN"
  },
  "dm": {
    "policy": "allowlist",
    "allowFrom": ["@driver:matrix.example.invalid"]
  },
  "groups": {
    "!upgrade-survivor:matrix.example.invalid": {
      "enabled": true,
      "requireMention": true,
      "tools": {
        "allow": ["message_send"],
        "deny": ["exec"]
      }
    }
  }
}
