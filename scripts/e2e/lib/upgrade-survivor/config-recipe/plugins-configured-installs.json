{
  "enabled": true,
  "allow": ["brave", "discord", "telegram", "matrix"],
  "entries": {
    "brave": {
      "enabled": true,
      "config": {
        "webSearch": {
          "apiKey": {
            "source": "env",
            "provider": "default",
            "id": "BRAVE_API_KEY"
          }
        }
      }
    },
    "discord": {
      "enabled": true
    },
    "matrix": {
      "enabled": true
    },
    "telegram": {
      "enabled": true
    }
  }
}
