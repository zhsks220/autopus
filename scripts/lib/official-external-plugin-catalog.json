{
  "entries": [
    {
      "name": "@autopus/acpx",
      "description": "Autopus ACP runtime backend",
      "source": "official",
      "kind": "plugin",
      "autopus": {
        "plugin": {
          "id": "acpx",
          "label": "ACPX Runtime"
        },
        "install": {
          "npmSpec": "@autopus/acpx",
          "defaultChoice": "npm",
          "minHostVersion": ">=2026.4.25"
        }
      }
    },
    {
      "name": "@autopus/brave-plugin",
      "description": "Autopus Brave plugin",
      "source": "official",
      "kind": "plugin",
      "autopus": {
        "plugin": {
          "id": "brave",
          "label": "Brave"
        },
        "webSearchProviders": [
          {
            "id": "brave",
            "label": "Brave Search",
            "hint": "Brave Search web results.",
            "onboardingScopes": ["text-inference"],
            "credentialLabel": "Brave Search API key",
            "envVars": ["BRAVE_API_KEY"],
            "placeholder": "BSA...",
            "signupUrl": "https://api-dashboard.search.brave.com/app/keys",
            "docsUrl": "https://docs.autopus.ai/tools/brave-search",
            "credentialPath": "plugins.entries.brave.config.webSearch.apiKey",
            "autoDetectOrder": 10
          }
        ],
        "install": {
          "npmSpec": "@autopus/brave-plugin",
          "defaultChoice": "npm",
          "minHostVersion": ">=2026.4.10"
        }
      }
    },
    {
