{
  "name": "@autopus/google-meet",
  "version": "2026.5.12-beta.1",
  "description": "Autopus Google Meet participant plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/autopus/autopus"
  },
  "type": "module",
  "dependencies": {
    "commander": "14.0.3",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@autopus/plugin-sdk": "workspace:*",
    "autopus": "workspace:*"
  },
  "peerDependencies": {
    "autopus": ">=2026.5.12-beta.1"
  },
  "peerDependenciesMeta": {
    "autopus": {
      "optional": true
    }
  },
  "autopus": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@autopus/google-meet",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "autopusVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
