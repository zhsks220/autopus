{
  "name": "@autopus/feishu",
  "version": "2026.5.12-beta.1",
  "description": "Autopus Feishu/Lark channel plugin (community maintained by @m1heng)",
  "repository": {
    "type": "git",
    "url": "https://github.com/autopus/autopus"
  },
  "type": "module",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "1.63.1",
    "typebox": "1.1.38",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@autopus/plugin-sdk": "workspace:*",
    "autopus": "workspace:*"
  },
  "peerDependencies": {
    "autopus": ">=2026.5.12-beta.1"
  },
  "peerDependenciesMeta": {
    "autopus": {
      "optional": true
    }
  },
  "autopus": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "feishu",
      "label": "Feishu",
      "selectionLabel": "Feishu/Lark (飞书)",
      "docsPath": "/channels/feishu",
      "docsLabel": "feishu",
      "blurb": "飞书/Lark enterprise messaging with doc/wiki/drive tools.",
      "aliases": [
        "lark"
      ],
      "order": 35,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@autopus/feishu",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.25"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "autopusVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
