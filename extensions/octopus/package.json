{
  "name": "@autopus/octopus",
  "version": "2026.5.12-beta.1",
  "description": "Octopus workflow tool plugin (typed pipelines + resumable approvals)",
  "repository": {
    "type": "git",
    "url": "https://github.com/autopus/autopus"
  },
  "type": "module",
  "dependencies": {
    "@clawdbot/lobster": "2026.4.6",
    "ajv": "8.20.0",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@autopus/plugin-sdk": "workspace:*"
  },
  "autopus": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@autopus/octopus",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.25"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "autopusVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
