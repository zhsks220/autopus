{
  "name": "@autopus/diagnostics-otel",
  "version": "2026.5.12-beta.1",
  "description": "Autopus diagnostics OpenTelemetry exporter",
  "repository": {
    "type": "git",
    "url": "https://github.com/autopus/autopus"
  },
  "type": "module",
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/api-logs": "0.217.0",
    "@opentelemetry/exporter-logs-otlp-proto": "0.217.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "0.217.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.217.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-logs": "0.217.0",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-node": "0.217.0",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.40.0"
  },
  "devDependencies": {
    "@autopus/plugin-sdk": "workspace:*"
  },
  "autopus": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@autopus/diagnostics-otel",
      "npmSpec": "@autopus/diagnostics-otel",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.25"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "autopusVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
