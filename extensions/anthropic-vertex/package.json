{
  "name": "@autopus/anthropic-vertex-provider",
  "version": "2026.5.12-beta.1",
  "description": "Autopus Anthropic Vertex provider plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/autopus/autopus"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "0.16.0",
    "@earendil-works/pi-agent-core": "0.74.0",
    "@earendil-works/pi-ai": "0.74.0"
  },
  "devDependencies": {
    "@autopus/plugin-sdk": "workspace:*"
  },
  "autopus": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@autopus/anthropic-vertex-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.12-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "autopusVersion": "2026.5.12-beta.1",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
