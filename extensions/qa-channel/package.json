{
  "name": "@autopus/qa-channel",
  "version": "2026.5.12-beta.1",
  "private": true,
  "description": "Autopus QA synthetic channel plugin",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./api.js": "./api.ts",
    "./runtime-api.js": "./runtime-api.ts",
    "./test-api.js": "./test-api.ts"
  },
  "dependencies": {
    "typebox": "1.1.38",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@autopus/plugin-sdk": "workspace:*",
    "autopus": "workspace:*"
  },
  "peerDependencies": {
    "autopus": ">=2026.5.12-beta.1"
  },
  "peerDependenciesMeta": {
    "autopus": {
      "optional": true
    }
  },
  "autopus": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "qa-channel",
      "label": "QA Channel",
      "selectionLabel": "QA Channel (Synthetic)",
      "detailLabel": "QA Channel",
      "docsPath": "/channels/qa-channel",
      "docsLabel": "qa-channel",
      "blurb": "Synthetic Slack-class transport for automated Autopus QA scenarios.",
      "systemImage": "checklist",
      "order": 999,
      "exposure": {
        "configured": false,
        "setup": false,
        "docs": false
      }
    }
  }
}
