{
  "name": "@autopus/nostr",
  "version": "2026.5.12-beta.1",
  "description": "Autopus Nostr channel plugin for NIP-04 encrypted DMs",
  "repository": {
    "type": "git",
    "url": "https://github.com/autopus/autopus"
  },
  "type": "module",
  "dependencies": {
    "nostr-tools": "2.23.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@autopus/plugin-sdk": "workspace:*",
    "autopus": "workspace:*"
  },
  "peerDependencies": {
    "autopus": ">=2026.5.12-beta.1"
  },
  "peerDependenciesMeta": {
    "autopus": {
      "optional": true
    }
  },
  "autopus": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "nostr",
      "label": "Nostr",
      "selectionLabel": "Nostr (NIP-04 DMs)",
      "docsPath": "/channels/nostr",
      "docsLabel": "nostr",
      "blurb": "Decentralized protocol; encrypted DMs via NIP-04.",
      "order": 55,
      "quickstartAllowFrom": true,
      "cliAddOptions": [
        {
          "flags": "--private-key <key>",
          "description": "Nostr private key (nsec... or hex)"
        },
        {
          "flags": "--relay-urls <list>",
          "description": "Nostr relay URLs (comma-separated)"
        }
      ]
    },
    "install": {
      "npmSpec": "@autopus/nostr",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "autopusVersion": "2026.5.12-beta.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
