{
  "name": "@autopus/amazon-bedrock-mantle-provider",
  "version": "2026.5.12-beta.1",
  "description": "Autopus Amazon Bedrock Mantle (OpenAI-compatible) provider plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/autopus/autopus"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "0.95.2",
    "@aws/bedrock-token-generator": "1.1.0",
    "@earendil-works/pi-ai": "0.74.0"
  },
  "devDependencies": {
    "@autopus/plugin-sdk": "workspace:*"
  },
  "autopus": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@autopus/amazon-bedrock-mantle-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.12-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.5.12-beta.1"
    },
    "build": {
      "autopusVersion": "2026.5.12-beta.1",
      "bundledDist": false
    },
    "release": {
      "publishToNpm": true
    }
  }
}
