// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

AUTOPUS_CODE_SIGN_STYLE = Automatic
AUTOPUS_DEVELOPMENT_TEAM = YOUR_TEAM_ID

AUTOPUS_APP_BUNDLE_ID = ai.autopus.client
AUTOPUS_SHARE_BUNDLE_ID = ai.autopus.client.share
AUTOPUS_ACTIVITY_WIDGET_BUNDLE_ID = ai.autopus.client.activitywidget
AUTOPUS_WATCH_APP_BUNDLE_ID = ai.autopus.client.watchkitapp
AUTOPUS_WATCH_EXTENSION_BUNDLE_ID = ai.autopus.client.watchkitapp.extension

// Leave empty with automatic signing.
AUTOPUS_APP_PROFILE =
AUTOPUS_SHARE_PROFILE =
AUTOPUS_WATCH_APP_PROFILE =
AUTOPUS_WATCH_EXTENSION_PROFILE =
